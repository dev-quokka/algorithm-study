#include <string>
#include <vector>
#include <algorithm>

using namespace std;

int answer = 0;
vector<bool> check;
void dfs(vector<vector<int>> d, int k, int cnt){
    for(int i=0; i<d.size(); i++){
        if(check[i]) continue;
        if(d[i][0] <= k){
            check[i] = true;
            dfs(d, k-d[i][1], cnt+1);
            check[i] = false;
        }
    }
    
    answer = max(answer, cnt);
}

int solution(int k, vector<vector<int>> dungeons) {
    check.resize(dungeons.size());
    dfs(dungeons, k, 0);
    return answer;
}